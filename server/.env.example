# ============================================================================
# PortFlow API Server — .env
# ============================================================================
# Copy to .env for local development (outside Docker).
# For Docker deployments, use the root-level .env.example instead.

# ============================================================================
# DATABASE
# ============================================================================
# Full connection string (preferred)
DATABASE_URL=postgresql://portflow:portflow@localhost:5432/portflow

# Or use individual params (db.ts supports both; DATABASE_URL wins if set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portflow
DB_USER=portflow
DB_PASSWORD=portflow

# ============================================================================
# SERVER
# ============================================================================
# Port the API listens on
PORT=3001

# development | production
NODE_ENV=development

# ============================================================================
# CORS
# ============================================================================
# Allowed origin for the frontend. Match where you serve the client from.
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT secret for signing tokens. REQUIRED.
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-in-production

# Token lifetime. Supports units: s, m, h, d (e.g. 24h, 7d)
JWT_EXPIRES_IN=24h

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================
# Public base URL used to build absolute links in notification emails
# (assignment notifications, subscriber notifications). Leave blank to
# omit links. SMTP settings themselves are configured in Settings > Email.
# Examples:
#   Local dev:    http://localhost:5173
#   Production:   https://portflow.example.com
APP_URL=
