# ============================================================================
# PortFlow — Root .env (for docker-compose deployments)
# ============================================================================
# Copy this file to .env and adjust values for your deployment.
# This file is used by docker-compose.yml to configure all containers.
# For local development (outside Docker), see server/.env.example instead.

# ============================================================================
# DATABASE (portflow-db container)
# ============================================================================
# PostgreSQL credentials. Used by the db container on first initialization
# AND by the api container to connect.
POSTGRES_USER=portflow
POSTGRES_PASSWORD=portflow
POSTGRES_DB=portflow

# Host port to expose PostgreSQL on (for external DB clients). Container
# always listens on 5432 internally.
DB_PORT=5432

# ============================================================================
# API SERVER (portflow-api container)
# ============================================================================
# Host port to expose the API on. Container always listens on 3001 internally.
API_PORT=3001

# JWT secret for signing authentication tokens. REQUIRED.
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-in-production

# Token expiration. Supports units: s, m, h, d (e.g. 24h, 7d)
JWT_EXPIRES_IN=24h

# Allowed CORS origin for the frontend. Match the URL you'll access PortFlow from.
# Examples:
#   Local dev:    http://localhost:5173
#   Production:   https://portflow.example.com
CORS_ORIGIN=http://localhost:5173

# Public base URL of the app. Used to build absolute links in notification emails.
# Leave blank to omit links from emails.
# Examples:
#   Local dev:    http://localhost:5173
#   Production:   https://portflow.example.com
APP_URL=

# ============================================================================
# CLIENT (portflow-client container)
# ============================================================================
# Host port to expose the web UI on. Container always listens on 80 internally.
CLIENT_PORT=5173
